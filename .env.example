KEY=your_bailian_api_key_here
SEEDREAM_KEY=your_volcengine_ark_api_key_here

# Optional Xiaoyou mobile App channel. Generate a long random token locally.
XIAOYOU_APP_ENABLED=false
XIAOYOU_APP_TOKEN=
XIAOYOU_APP_DEFAULT_PROACTIVE=false
XIAOYOU_APP_VOICE_ENABLED=true
XIAOYOU_APP_TEXT_VOICE_DECISION_ENABLED=true
# App TTS uses Volcengine Seed-TTS 2.0. Prefer the new API Key.
XIAOYOU_APP_TTS_API_KEY=
# Legacy Volcengine speech-console credentials; leave empty with API Key auth.
XIAOYOU_APP_TTS_APP_ID=
XIAOYOU_APP_TTS_ACCESS_KEY=

# Stable identity migration anchors (optional)
XIAOYOU_LEGACY_SESSION_IDS=
XIAOYOU_TARGET_WECHAT_ALIAS=
XIAOYOU_TARGET_REMARK_NAME=
XIAOYOU_TARGET_NICKNAME=
