#!/usr/bin/env bash
set -euo pipefail

# This file must be owned by root:root and must not be writable by the service user.
readonly PATH='/usr/sbin:/usr/bin:/sbin:/bin'
readonly CONTAINER='cow-legacy'

if [[ $# -ne 1 ]]; then
    echo 'usage: xiaoyou-ctl {status|stats|logs|start|stop|restart}' >&2
    exit 64
fi

action="$1"

container_exists() {
    docker inspect "$CONTAINER" >/dev/null 2>&1
}

host_cpu_percent() {
    local cpu user nice system idle iowait irq softirq steal guest guest_nice
    local idle_first total_first idle_second total_second delta_idle delta_total

    read -r cpu user nice system idle iowait irq softirq steal guest guest_nice < /proc/stat
    idle_first=$((idle + iowait))
    total_first=$((user + nice + system + idle + iowait + irq + softirq + steal))
    sleep 0.25
    read -r cpu user nice system idle iowait irq softirq steal guest guest_nice < /proc/stat
    idle_second=$((idle + iowait))
    total_second=$((user + nice + system + idle + iowait + irq + softirq + steal))
    delta_idle=$((idle_second - idle_first))
    delta_total=$((total_second - total_first))

    awk -v total="$delta_total" -v idle="$delta_idle" 'BEGIN {
        if (total <= 0) printf "0.0";
        else printf "%.1f", ((total - idle) * 100.0 / total);
    }'
}

host_memory_stats() {
    awk '
        function human(kb) {
            if (kb >= 1048576) return sprintf("%.2fGiB", kb / 1048576);
            if (kb >= 1024) return sprintf("%.1fMiB", kb / 1024);
            return sprintf("%dKiB", kb);
        }
        /^MemTotal:/ { total=$2 }
        /^MemAvailable:/ { available=$2 }
        END {
            if (total <= 0) {
                printf "0.0|0B / 0B";
                exit;
            }
            used=total-available;
            if (used < 0) used=0;
            printf "%.1f|%s / %s", used * 100.0 / total, human(used), human(total);
        }
    ' /proc/meminfo
}

case "$action" in
    status)
        if ! container_exists; then
            printf '%s\n' '{"exists":false,"running":false,"status":"missing","health":"none","started_at":"","finished_at":"","restart_count":0,"image":""}'
            exit 0
        fi
        docker inspect --format '{"exists":true,"running":{{json .State.Running}},"status":{{json .State.Status}},"health":{{if .State.Health}}{{json .State.Health.Status}}{{else}}"none"{{end}},"started_at":{{json .State.StartedAt}},"finished_at":{{json .State.FinishedAt}},"restart_count":{{json .RestartCount}},"image":{{json .Config.Image}}}' "$CONTAINER"
        ;;
    stats)
        host_cpu="$(host_cpu_percent)"
        IFS='|' read -r host_memory host_usage <<<"$(host_memory_stats)"

        container_cpu='0'
        container_memory='0'
        container_usage='0B / 0B'
        if container_exists && [[ "$(docker inspect --format '{{.State.Running}}' "$CONTAINER")" == 'true' ]]; then
            raw="$(docker stats --no-stream --format '{{.CPUPerc}}|{{.MemPerc}}|{{.MemUsage}}' "$CONTAINER")"
            IFS='|' read -r container_cpu container_memory container_usage <<<"$raw"
            container_cpu="${container_cpu%%%}"
            container_memory="${container_memory%%%}"
            [[ "$container_cpu" =~ ^[0-9]+([.][0-9]+)?$ ]] || container_cpu='0'
            [[ "$container_memory" =~ ^[0-9]+([.][0-9]+)?$ ]] || container_memory='0'
            container_usage="${container_usage//\\/}"
            container_usage="${container_usage//\"/}"
        fi

        printf '{"host_cpu_percent":%s,"host_memory_percent":%s,"host_memory_usage":"%s","container_cpu_percent":%s,"container_memory_percent":%s,"container_memory_usage":"%s","cpu_percent":%s,"memory_percent":%s,"memory_usage":"%s"}\n' \
            "$host_cpu" "$host_memory" "$host_usage" \
            "$container_cpu" "$container_memory" "$container_usage" \
            "$container_cpu" "$container_memory" "$container_usage"
        ;;
    logs)
        if container_exists; then
            # Registration and initialization happen at the very beginning of
            # a container run and quickly fall outside the recent tail. Keep
            # lifecycle lines from the first ten minutes, then append the recent
            # operational tail. Read the tail across container restarts so a
            # token event emitted just before a crash is still persisted by
            # the next metrics sample.
            started_at="$(docker inspect --format '{{.State.StartedAt}}' "$CONTAINER")"
            started_epoch="$(date -d "$started_at" +%s 2>/dev/null || true)"
            if [[ "$started_epoch" =~ ^[0-9]+$ ]]; then
                startup_until="$(date -u -d "@$((started_epoch + 600))" '+%Y-%m-%dT%H:%M:%SZ')"
                docker logs --since "$started_at" --until "$startup_until" "$CONTAINER" 2>&1 \
                    | while IFS= read -r line; do
                        case "$line" in
                            *"Plugin "*" registered"*|*" inited"*|*"Wechat login success"*|*"Start auto replying"*|*"Ready to login"*|*"Getting uuid of QR code"*|*"https://login.weixin.qq.com/l/"*)
                                printf '%s\n' "$line"
                                ;;
                        esac
                    done
            fi
            docker logs --tail 3000 "$CONTAINER" 2>&1
        fi
        ;;
    start)
        container_exists || { echo 'cow-legacy container does not exist' >&2; exit 3; }
        docker start "$CONTAINER" >/dev/null
        ;;
    stop)
        container_exists || { echo 'cow-legacy container does not exist' >&2; exit 3; }
        docker stop --time 20 "$CONTAINER" >/dev/null
        ;;
    restart)
        container_exists || { echo 'cow-legacy container does not exist' >&2; exit 3; }
        docker restart --time 20 "$CONTAINER" >/dev/null
        ;;
    *)
        echo 'unsupported action' >&2
        exit 64
        ;;
esac
